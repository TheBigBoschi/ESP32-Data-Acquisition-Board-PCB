	(text_box "Panel -> CN3791 -> Battery -> TP4056 (for UVLO and USB charging) -> TPS63020 for main power (3.3V) + Aux 5V (SPS30)\n\nTPS63020 enabled by default. External pulldown connection needed to disable them (only for aux 5V)."
		(exclude_from_sim no)
		(at 17.78 20.32 0)
